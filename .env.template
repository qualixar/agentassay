# AgentAssay Experiment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git (already in .gitignore)

# ============================================================================
# Azure AI Foundry — Subscription 1
# ============================================================================
AZURE_SUB1_NAME=subscription-1
AZURE_SUB1_ENDPOINT=https://your-foundry-project-1.openai.azure.com
AZURE_SUB1_API_KEY=your-api-key-here
AZURE_SUB1_API_VERSION=2024-12-01-preview

# Model deployment names for Sub 1 (as deployed in Foundry)
AZURE_SUB1_MODELS=gpt-5.2-chat,claude-opus-4-6,kimi-k2-thinking,deepseek-v3.2-speciale

# ============================================================================
# Azure AI Foundry — Subscription 2
# ============================================================================
AZURE_SUB2_NAME=subscription-2
AZURE_SUB2_ENDPOINT=https://your-foundry-project-2.openai.azure.com
AZURE_SUB2_API_KEY=your-api-key-here
AZURE_SUB2_API_VERSION=2024-12-01-preview

# Model deployment names for Sub 2
AZURE_SUB2_MODELS=claude-sonnet-4-6,mistral-large-3,llama-3.3-70b-instruct,llama-4-maverick-17b

# ============================================================================
# Azure AI Foundry — Subscription 3
# ============================================================================
AZURE_SUB3_NAME=subscription-3
AZURE_SUB3_ENDPOINT=https://your-foundry-project-3.openai.azure.com
AZURE_SUB3_API_KEY=your-api-key-here
AZURE_SUB3_API_VERSION=2024-12-01-preview

# Model deployment names for Sub 3
AZURE_SUB3_MODELS=claude-sonnet-4-5,claude-opus-4-5,claude-haiku-4-5

# ============================================================================
# Azure VM (for unattended experiment execution)
# ============================================================================
AZURE_VM_RESOURCE_GROUP=agentassay-experiments
AZURE_VM_NAME=agentassay-runner
AZURE_VM_REGION=eastus2

# ============================================================================
# Experiment Settings
# ============================================================================
EXPERIMENT_BATCH_SIZE=50
EXPERIMENT_MAX_RETRIES=3
EXPERIMENT_CHECKPOINT_INTERVAL=25
EXPERIMENT_LOG_LEVEL=INFO

# ============================================================================
# Azure Blob Storage (for results push — populated automatically by setup-vm.sh)
# The daemon pushes results to Blob Storage every 30 minutes.
# Mac pulls from Blob Storage using pull-results.sh (no SSH needed).
# ============================================================================
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=experiment-results
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_SAS_TOKEN=
